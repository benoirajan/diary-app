rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safer function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    match /users/{userId} {
      // Allow users to read and write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow admins to read any user profile
      allow read: if isAdmin();
    }

    match /users/{userId}/entries/{entryId} {
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    match /users/{userId}/habits/{habitId} {
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    match /feedback/{feedbackId} {
      // Allow any authenticated user to create feedback
      allow create: if request.auth != null;
      // Only allow admins to read feedback
      allow read: if isAdmin();
    }
  }
}